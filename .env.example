# Runtime
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5278
FRONTEND_PORT=4200

# PostgreSQL
# Local Docker uses Host=postgres because that is the docker-compose service name.
# On HostGator VPS, keep the same database/user/password idea and use Host=localhost
# if the API runs directly on the VPS, or Host=postgres if both run in Docker Compose.
POSTGRES_DB=medishop
POSTGRES_USER=medishop
POSTGRES_PASSWORD=CHANGE_THIS_LOCAL_OR_SERVER_PASSWORD
POSTGRES_PORT=5432
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=medishop;Username=medishop;Password=CHANGE_THIS_LOCAL_OR_SERVER_PASSWORD;Include Error Detail=true

# JWT
# Use at least 32 characters. Do not commit the real value.
Jwt__Secret=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_WITH_32_OR_MORE_CHARS
Jwt__Issuer=MediShopAPI
Jwt__Audience=MediShopFrontend
Jwt__ExpirationHours=24
